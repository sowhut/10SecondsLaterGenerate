{
  "name": "10s-later-editor",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source, browser-based level editor for 10 Seconds Later — build a level, playtest it in the real Cocos engine, export/submit.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=18.18",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "levels:validate": "pnpm --filter @10s/schema build && node tools/levels.mjs validate",
    "levels:approve": "pnpm --filter @10s/schema build && node tools/levels.mjs approve",
    "levels:adopt": "pnpm --filter @10s/schema build && node tools/levels.mjs adopt",
    "levels:apply": "pnpm --filter @10s/schema build && node tools/levels.mjs apply",
    "levels:release": "pnpm --filter @10s/schema build && node tools/levels.mjs release",
    "schema:check": "pnpm --filter @10s/schema schema:check",
    "typecheck": "pnpm --filter @10s/schema build && pnpm -r --if-present typecheck",
    "lint": "eslint . --max-warnings 0",
    "test": "pnpm --filter @10s/schema build && pnpm -r --if-present test",
    "dev": "pnpm --filter @10s/schema build && pnpm --filter @10s/editor dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "ajv": "8.17.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.18.0",
    "typescript": "^5.7.2"
  }
}
