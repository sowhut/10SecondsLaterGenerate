{
  "name": "@10s/editor",
  "version": "0.0.0",
  "private": true,
  "description": "10 Seconds Later — public browser level editor (Canvas authoring on top of @10s/schema).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@10s/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
